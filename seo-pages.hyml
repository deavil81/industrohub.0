<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Industrial Suppliers Directory | IndustroHub</title>

<link rel="stylesheet" href="css/style.css">

</head>

<body>

<header style="background:#0f172a;color:white;padding:20px;">
<h2>IndustroHub</h2>
</header>


<section style="padding:40px;max-width:1000px;margin:auto">

<h1>Industrial Suppliers Directory</h1>

<p>Browse industrial suppliers and service providers across major industrial cities.</p>

<div id="seoLinks"></div>

</section>


<footer style="background:#0f172a;color:white;padding:20px;text-align:center">
© 2026 IndustroHub
</footer>


<script>

const products = [

"ms-rod",
"ms-pipe",
"steel-plate",
"steel-angle",
"fabrication-service",
"machine-shop",
"laser-cutting",
"cnc-machining",
"sheet-metal"

]

const cities = [

"vadodara",
"bharuch",
"ankleshwar",
"surat",
"ahmedabad",
"vapi",
"halol",
"dahej",
"savli-gidc",
"makarpura-gidc"

]

const container = document.getElementById("seoLinks")

cities.forEach(city => {

const cityTitle = city.replaceAll("-", " ")
const cityHeader = document.createElement("h2")

cityHeader.innerText = cityTitle.toUpperCase()

container.appendChild(cityHeader)

const ul = document.createElement("ul")

products.forEach(product => {

const name = product.replaceAll("-", " ")

const li = document.createElement("li")

li.innerHTML = `
<a href="product.html?item=${product}&city=${city}">
${name.replace(/\b\w/g,l=>l.toUpperCase())} Supplier ${cityTitle.replace(/\b\w/g,l=>l.toUpperCase())}
</a>
`

ul.appendChild(li)

})

container.appendChild(ul)

})

</script>

</body>
</html>